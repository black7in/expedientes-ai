# ─── Base de datos ────────────────────────────────────────────────────────────
# En desarrollo local: apunta al contenedor expedientes_postgres
# En Docker (expedientes-deploy): se inyecta automáticamente por docker-compose
DATABASE_URL=postgresql://laravel:secret@localhost:5432/expedientes_juridicos

# ─── Almacenamiento de documentos ─────────────────────────────────────────────
# Ruta donde están los PDFs/DOCX subidos desde Laravel
# En Docker: se monta como volumen compartido con expedientes-app
STORAGE_PATH=/storage/documentos

# ─── LLM — Proveedor y modelo ────────────────────────────────────────────────
# llm_provider: "anthropic" (incluye OpenCode Go compatible) | "openai"
LLM_PROVIDER=anthropic

# Anthropic nativo o proveedor compatible (OpenCode, etc.)
#
# Anthropic nativo:
#   ANTHROPIC_API_KEY=sk-ant-...
#   LLM_BASE_URL=
#   LLM_MODEL=claude-sonnet-4-6
#
# OpenCode.ai Zen Go (suscripción de Adrian):
#   ANTHROPIC_API_KEY=<opencode-key>
#   LLM_BASE_URL=https://opencode.ai/zen/go   # sin /v1
#   LLM_MODEL=kimi-k2.6
ANTHROPIC_API_KEY=tu-api-key
LLM_BASE_URL=https://opencode.ai/zen/go
LLM_MODEL=kimi-k2.6

# OpenAI (si LLM_PROVIDER=openai)
OPENAI_API_KEY=

# ─── Modelo de embeddings (NLP local) ─────────────────────────────────────────
# Modelo intfloat/multilingual-e5-large (~1.2GB) — se descarga automáticamente
# Se cachea en el volumen huggingface_cache para no re-descargar en rebuilds
TRANSFORMERS_CACHE=/app/.cache/huggingface
